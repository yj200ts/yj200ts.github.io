---
const siteName = "小庭小世界";
const diaryEntries = [
  {
    date: "2026-03-23 我在碎碎念",
    mood: "开心",
    content: "音影书评里的书评为测试用，留言板提问箱热火朝天测试中！！！但是呢我还没有研究好。唉，我不知道明信片界面怎么设置，好苦恼！！！",
  },
  {
    date: "2026-03-23 我在图书馆嘻嘻",
    mood: "开心",
    content: "今天是软2对亚韩汉，呃软2不出意外地失败了，但是天气很好，心情也很好！",
    image: "/assets/guahaoxin.jpg",
  },
  {
    date: "2026-03-22 我在吃麦麦美味哦",
    mood: "开心",
    content: "晚上吃了麦香鱼，超美味！！",
    image: "/assets/maixiangyu.jpg",
  },
  {
    date: "2026-03-24 我的私密小日记",
    mood: "伤心",
    content: "这是我的小秘密！！终于能看见了！！",
    private: true,
  }
];

const total = diaryEntries.length;
const happyCount = diaryEntries.filter(x => x.mood === "开心").length;
const calmCount = diaryEntries.filter(x => x.mood === "平静").length;
const angryCount = diaryEntries.filter(x => x.mood === "愤怒").length;
const sadCount = diaryEntries.filter(x => x.mood === "伤心").length;

let noticeText = "小庭最近心情很美丽呀！";
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <title>小日记</title>
  <style is:raw>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:Microsoft YaHei;background:#fff0f6;background-image:radial-gradient(pink 1px,transparent 1px);background-size:20px 20px}
    nav{background:rgba(255,255,255,.95);padding:1rem;position:sticky;top:0;box-shadow:0 2px 10px rgba(230,73,128,.1)}
    .nav{display:flex;gap:1.5rem;max-width:1000px;margin:auto}
    .nav a{text-decoration:none;color:#666}
    .nav a[href="/diary"]{color:#e64980;font-weight:bold}

    .tips{background:#fff5fa;color:#e64980;padding:8px;text-align:center;white-space:nowrap;overflow:hidden}
    .tips span{display:inline-block;animation:run 10s linear infinite}
    @keyframes run{0%{transform:translateX(100%)}100%{transform:translateX(-100%)}}

    .tabs{max-width:800px;margin:1rem auto;display:flex;gap:8px;flex-wrap:wrap;padding:0 1rem}
    .tab{padding:6px 12px;border-radius:30px;border:none;background:#fff;cursor:pointer}
    .tab.happy{background:#ffdef2;color:#e64980}
    .tab.calm{background:#e8f4fd;color:#4285f4}
    .tab.angry{background:#ffe5e5;color:#ea4335}
    .tab.sad{background:#f3e5ff;color:#9c27b0}

    .box{max-width:800px;margin:auto;padding:1rem}
    .card{background:#fff;padding:1rem;border-radius:12px;margin-bottom:1rem}
    .tag{display:inline-block;padding:4px 8px;border-radius:10px;font-size:12px;margin:5px 0}
    .tag.happy{background:#ffdef2;color:#e64980}
    .tag.calm{background:#e8f4fd;color:#4285f4}
    .tag.angry{background:#ffe5e5;color:#ea4335}
    .tag.sad{background:#f3e5ff;color:#9c27b0}
    .date{color:#999;margin:5px 0}

    .priv{border:2px dashed #e64980;padding:10px;border-radius:10px;margin-top:10px}
    .priv input{width:100%;padding:8px;margin:5px 0;border:1px solid #e64980;border-radius:8px}
    .priv button{width:100%;padding:8px;background:#e64980;color:white;border:none;border-radius:8px;cursor:pointer}
    .unlocked-content{background:#fff0f6;padding:10px;border-radius:8px;margin-top:5px}
  </style>
</head>

<body>

<nav>
  <div class="nav">
    <a href="/">首页</a>
    <a href="/diary">小日记</a>
    <a href="/review">音影书评</a>
    <a href="/guestbook">留言板</a>
    <a href="/ask">提问箱</a>
    <a href="/postcard">明信片</a>
    <a href="/about">关于我</a>
  </div>
</nav>

<div class="tips"><span>{noticeText}</span></div>

<div class="tabs">
  <button class="tab" onclick="show('all')">全部 ({total})</button>
  <button class="tab happy" onclick="show('开心')">😊 开心 ({happyCount})</button>
  <button class="tab calm" onclick="show('平静')">😌 平静 ({calmCount})</button>
  <button class="tab angry" onclick="show('愤怒')">😠 愤怒 ({angryCount})</button>
  <button class="tab sad" onclick="show('伤心')">😢 伤心 ({sadCount})</button>
</div>

<div class="box">
  {diaryEntries.map((it, i) => (
    <div class="card" data-mood={it.mood}>
      {it.mood === "开心" && <span class="tag happy">😊 开心</span>}
      {it.mood === "平静" && <span class="tag calm">😌 平静</span>}
      {it.mood === "愤怒" && <span class="tag angry">😠 愤怒</span>}
      {it.mood === "伤心" && <span class="tag sad">😢 伤心</span>}
      <div class="date">{it.date}</div>

      {!it.private ? (
        <p>{it.content}</p>
      ) : (
        <div class="priv" id="box{i}">
          🔒 私密日记
          <input type="password" id="pw{i}" placeholder="密码">
          <button onclick="unlock({i}, `{it.content.replace(/`/g, '\\`')}`)">解锁</button>
        </div>
      )}

      {it.image && <img src={it.image} style="max-width:50%;border-radius:8px;margin-top:10px">}
    </div>
  ))}
</div>

<script is:inline>
function show(m){
  document.querySelectorAll(".card").forEach(c=>{
    c.style.display = m=="all"||c.dataset.mood==m ? "block" : "none";
  });
}

function unlock(i, content){
  let pw = document.getElementById("pw"+i).value;
  if(pw === "123456"){
    document.getElementById("box"+i).innerHTML = `
      <div class="unlocked-content">
        ✅ 解锁成功！<br><br>
        📖 日记内容：<br>
        ${content}
      </div>
    `;
  }else{
    alert("密码错啦！再试试看～");
  }
}
</script>

</body>
</html>