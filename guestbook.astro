<!-- 修复乱码 + 粉色主题样式 -->
<head>
  <meta charset="UTF-8" />
  <style>
    /* 全局粉色主题变量 */
    :root {
      --giscus-primary: #f8bbd0;
      --giscus-bg: #fff5f8;
      --giscus-border: #f48fb1;
      --giscus-text: #424242;
    }
    /* 页面文字样式 */
    main h1, main p {
      color: var(--giscus-text);
      font-family: system-ui, -apple-system, sans-serif;
    }
    /* 覆盖 giscus 默认样式，实现粉色主题 */
    .giscus {
      background: var(--giscus-bg) !important;
      border-radius: 12px !important;
      padding: 16px !important;
      border: 1px solid var(--giscus-border) !important;
      margin-top: 20px;
    }
    .giscus .giscus-header,
    .giscus .giscus-button {
      background: var(--giscus-primary) !important;
      border-color: var(--giscus-border) !important;
      color: var(--giscus-text) !important;
    }
    .giscus .giscus-textarea {
      background: #ffffff !important;
      border-color: var(--giscus-border) !important;
    }
    .giscus .giscus-comment {
      border-bottom: 1px solid var(--giscus-border) !important;
    }
  </style>
</head>

<main>
  <h1>留言板</h1>
  <p>欢迎留下你的想法</p >
</main>

