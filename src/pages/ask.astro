---
layout: "../layouts/Base.astro"
title: "提问留言板"
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
</head>

<style is:raw>
* {
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body {
  font-family: SimSun, "宋体", sans-serif;
  background: #fff0f6;
  background-image: radial-gradient(pink 1px, transparent 1px);
  background-size: 20px 20px;
  font-size:14px;
  line-height:1.6;
  color:#333;
}

/* 导航栏：和日记页完全一样 */
nav {
  width: 92%;
  max-width: 800px;
  margin: 10px auto;
  border: 2px solid #F4A7C1;
  background: #FFF;
  padding: 8px;
  text-align: center;
}
.nav-links {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6px;
}
.nav-links a {
  color: #C45A81;
  text-decoration: none;
  font-size: 14px;
  padding: 4px 8px;
  border: 1px solid #F4A7C1;
  background: #FFE6F0;
  font-family: SimSun, "宋体" !important;
}
.nav-links a:hover {
  background: #F4A7C1;
  color: #FFF;
}
.nav-links a.active {
  background: #F4A7C1;
  color: #FFF;
  font-weight: normal;
}

.page {
  max-width: 800px;
  margin: 20px auto;
  padding: 0 1rem;
}
.page-header {
  text-align: center;
  margin-bottom: 16px;
}
.page-header h1 {
  color: #e64980;
  font-size: 20px;
  font-family: SimSun, "宋体";
}

.question-form {
  background: #fff;
  border: 1px solid #F4A7C1;
  padding: 12px;
  margin-bottom: 12px;
}
.form-title {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 10px;
  font-size: 14px;
  color: #e64980;
}
.question-form textarea {
  width: 100%;
  padding: 8px;
  border: 1px solid #F4A7C1;
  font-size: 14px;
  font-family: SimSun, "宋体";
  margin-bottom: 8px;
}
.question-form button {
  background: #e64980;
  color: white;
  border: none;
  padding: 6px 16px;
  font-size: 14px;
  font-family: SimSun, "宋体";
  cursor: pointer;
}

.questions-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.question-card {
  background: #fff;
  border: 1px solid #C45A81;
  padding: 12px;
}
.card-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  padding-bottom: 6px;
  border-bottom: 1px solid #ffe6f0;
}
.question-meta {
  display: flex;
  gap: 8px;
}
.question-number {
  background: #e64980;
  color: white;
  padding: 2px 6px;
  font-size: 12px;
}
.question-date {
  color: #999;
  font-size: 12px;
}
.status-badge {
  padding: 2px 6px;
  font-size: 12px;
}
.status-badge.answered { background: #e8f5e9; color: #4caf50; }
.status-badge.waiting { background: #fff3e0; color: #ff9800; }
.delete-btn {
  background: none;
  border: none;
  color: #ccc;
  cursor: pointer;
}
.question-content {
  background: #fffafc;
  padding: 8px;
  border-left: 2px solid #e64980;
  margin-bottom: 8px;
}
.question-label {
  font-size: 12px;
  color: #e64980;
  margin-bottom: 4px;
}
.question-text {
  font-size: 14px;
}
.answer-box {
  background: #fff0f6;
  padding: 8px;
  border-left: 2px solid #f48fb1;
}
.answer-label {
  font-size: 12px;
  color: #e64980;
  margin-bottom: 4px;
}
.answer-text {
  font-size: 14px;
  color: #666;
}
.waiting-text {
  background: #f9f9f9;
  padding: 6px;
  text-align: center;
  color: #999;
  font-size: 12px;
}
.answer-input-wrapper {
  display: flex;
  gap: 8px;
}
.answer-input-wrapper input {
  flex: 1;
  padding: 6px;
  border: 1px solid #F4A7C1;
  font-size: 14px;
}
.answer-submit-btn {
  padding: 6px 14px;
  background: #e64980;
  color: white;
  border: none;
  cursor: pointer;
  font-size: 14px;
}
.empty-state {
  text-align: center;
  padding: 20px;
  background: #fff;
  border: 1px solid #F4A7C1;
  color: #999;
}
footer {
  text-align: center;
  margin: 30px 0;
  color: #999;
  font-size: 12px;
}
</style>

<body>
<nav>
  <div class="nav-links">
    <a href="/">首页</a>
    <a href="/diary">小日记</a>
    <a href="/review">音影书评</a>
    <a href="/guestbook">留言板</a>
    <a href="/ask" class="active">提问箱</a>
    <a href="/postcard">明信片</a>
    <a href="/about">关于我</a>
  </div>
</nav>

<main class="page">
  <div class="page-header">
    <h1>💌 提问留言板</h1>
    <p>无需登录，直接留下你的评论和提问</p>
  </div>

  <div class="question-form">
    <div class="form-title">
      <span>📝</span>
      <span>写下你的问题</span>
    </div>
    <textarea id="questionInput" rows="3" placeholder="想对小庭说什么？"></textarea>
    <button onclick="submitQuestion()">✨ 匿名提问</button>
  </div>

  <div class="questions-list" id="questionsList"></div>
</main>

<footer>
  © 2026 小庭小世界
</footer>

<script is:inline>
const ADMIN_PASSWORD = "xiaoting520";
let questions = [];
let isAdmin = false;

function loadFromStorage() {
  const saved = localStorage.getItem('questions_data_final');
  if (saved) questions = JSON.parse(saved);
  renderQuestions();
}
function saveToStorage() {
  localStorage.setItem('questions_data_final', JSON.stringify(questions));
}
function renderQuestions() {
  const container = document.getElementById('questionsList');
  if (questions.length === 0) {
    container.innerHTML = `<div class="empty-state">还没有提问～</div>`;
    return;
  }
  const sorted = [...questions].reverse();
  container.innerHTML = sorted.map((q, idx) => {
    const ori = questions.findIndex(x => x.id === q.id);
    const no = questions.length - ori;
    return `
      <div class="question-card" data-id="${q.id}">
        <div class="card-header">
          <div class="question-meta">
            <span class="question-number">#${no}</span>
            <span class="question-date">📅 ${q.date}</span>
            <span class="status-badge ${q.answered?'answered':'waiting'}">
              ${q.answered?'✓ 已回复':'⏳ 等待回复'}
            </span>
          </div>
          ${isAdmin?`<button class="delete-btn" onclick="deleteQuestion(${ori})">🗑️</button>`:''}
        </div>
        <div class="question-content">
          <div class="question-label">💬 提问</div>
          <div class="question-text">${escapeHtml(q.content)}</div>
        </div>
        <div class="answer-area">
          ${q.answered?`
          <div class="answer-box">
            <div class="answer-label">💖 小庭的回答</div>
            <div class="answer-text">${escapeHtml(q.answer)}</div>
          </div>`:
          isAdmin?`
          <div class="answer-input-wrapper">
            <input type="text" id="answer_${ori}" placeholder="写下回答">
            <button class="answer-submit-btn" onclick="submitAnswer(${ori})">回复</button>
          </div>`:`
          <div class="waiting-text">⏳ 等待回复中...</div>`}
        </div>
      </div>
    `;
  }).join('');
}
function submitQuestion() {
  const t = document.getElementById('questionInput').value.trim();
  if (!t) { alert('请输入内容'); return; }
  const now = new Date();
  const d = `${now.getFullYear()}-${(now.getMonth()+1+'').padStart(2,0)}-${(now.getDate()+'').padStart(2,0)} ${(now.getHours()+'').padStart(2,0)}:${(now.getMinutes()+'').padStart(2,0)}`;
  questions.push({id:Date.now(), content:t, answer:'', date:d, answered:false});
  saveToStorage();
  renderQuestions();
  document.getElementById('questionInput').value = '';
  alert('提问成功！');
}
function submitAnswer(i) {
  if (!isAdmin) return;
  const v = document.getElementById(`answer_${i}`).value.trim();
  if (!v) return;
  questions[i].answer = v;
  questions[i].answered = true;
  saveToStorage();
  renderQuestions();
}
function deleteQuestion(i) {
  if (!isAdmin) return;
  if(confirm('确定删除？')){
    questions.splice(i,1);
    saveToStorage();
    renderQuestions();
  }
}
function toggleAdmin() {
  if(isAdmin){
    isAdmin = false;
    adminBtn.innerHTML = '🔒';
  }else{
    const p = prompt('管理员密码：');
    if(p===ADMIN_PASSWORD){
      isAdmin = true;
      adminBtn.innerHTML = '🔓';
    }else if(p!=null)alert('密码错误');
  }
  renderQuestions();
}
function escapeHtml(s){
  return s? s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') : '';
}
loadFromStorage();
</script>
</body>
</html>