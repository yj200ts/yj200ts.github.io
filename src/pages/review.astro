---
const siteName = "小庭小世界";
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>音影书评 | {siteName}</title>
  
  <style is:raw>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* ========== 全站统一：宋体 + 一模一样波点背景 ========== */
    body {
      font-family: SimSun, "宋体", sans-serif;
      background: #fff0f6;
      background-image: radial-gradient(pink 1px, transparent 1px);
      background-size: 20px 20px;
      font-size: 14px;
      line-height: 1.6;
      color: #333;
    }

    /* ========== 导航栏：和日记页完全一样 ========== */
    nav {
      width: 92%;
      max-width: 800px;
      margin: 10px auto;
      border: 2px solid #F4A7C1;
      background: #FFF;
      padding: 8px;
      text-align: center;
    }
    .nav-container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }
    .nav-logo {
      display: none;
    }
    .nav-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }
    .nav-links a {
      color: #C45A81;
      text-decoration: none;
      font-size: 14px;
      padding: 4px 8px;
      border: 1px solid #F4A7C1;
      background: #FFE6F0;
      font-family: SimSun, "宋体" !important;
    }
    .nav-links a:hover {
      background: #F4A7C1;
      color: #FFF;
    }
    .nav-links a.active {
      background: #F4A7C1;
      color: #FFF;
      font-weight: normal;
    }

    /* 页面主体 */
    .page {
      max-width: 800px;
      margin: 20px auto;
      padding: 0 1rem;
    }
    .page h1 {
      color: #e64980;
      margin-bottom: 16px;
      font-size: 20px;
      text-align: center;
      font-family: SimSun, "宋体";
    }
    
    /* 分类标签（古早风格） */
    .category-tabs {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .category-tab {
      padding: 4px 8px;
      background: #FFE6F0;
      border: 1px solid #F4A7C1;
      cursor: pointer;
      font-family: SimSun, "宋体";
    }
    .category-tab.active {
      background: #F4A7C1;
      color: #FFF;
    }

    /* 音乐二级分类 */
    .music-sub-tabs {
      display: flex;
      justify-content: center;
      gap: 6px;
      margin: 0 0 16px;
      flex-wrap: wrap;
    }
    .music-sub-tab {
      padding: 3px 6px;
      background: #FFE6F0;
      border: 1px solid #F4A7C1;
      cursor: pointer;
      font-family: SimSun, "宋体";
      font-size: 12px;
    }
    .music-sub-tab.active {
      background: #F4A7C1;
      color: #FFF;
    }

    /* 卡片容器（古早单列） */
    .review-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    
    /* 卡片：古早粉色边框 */
    .review-card {
      background: #fff;
      border: 1px solid #C45A81;
      padding: 12px;
    }
    .review-card h3 {
      color: #e64980;
      margin-bottom: 6px;
      font-size: 14px;
      font-family: SimSun, "宋体";
    }
    .tag, .sub-tag {
      display: inline-block;
      font-size: 12px;
      padding: 2px 6px;
      background: #FFE6F0;
      color: #C45A81;
      border: 1px solid #F4A7C1;
      margin-bottom: 8px;
      margin-right: 4px;
    }
    .rating {
      color: #e64980;
      margin-bottom: 8px;
      font-size: 12px;
    }
    .desc {
      color: #333;
      margin-bottom: 8px;
      font-size: 14px;
      line-height: 1.6;
    }
    .date {
      font-size: 12px;
      color: #999;
    }

    footer {
      text-align: center;
      margin: 30px 0;
      color: #999;
      font-size: 12px;
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-container">
    <div class="nav-links">
      <a href="/">首页</a>
      <a href="/diary">小日记</a>
      <a href="/review" class="active">音影书评</a>
      <a href="/guestbook">留言板</a>
      <a href="/ask">提问箱</a>
      <a href="/postcard">明信片</a>
      <a href="/about">关于我</a>
    </div>
  </div>
</nav>

<main class="page">
  <h1>🎵 我的音影书评</h1>
  
  <div class="category-tabs">
    <div class="category-tab active" data-category="全部">全部</div>
    <div class="category-tab" data-category="音乐">音乐</div>
    <div class="category-tab" data-category="书籍">书籍</div>
    <div class="category-tab" data-category="电影">电影</div>
    <div class="category-tab" data-category="剧集">剧集</div>
    <div class="category-tab" data-category="综艺">综艺</div>
  </div>

  <div class="music-sub-tabs" id="musicSubTabs" style="display: none;">
    <div class="music-sub-tab active" data-subcategory="全部">全部音乐</div>
    <div class="music-sub-tab" data-subcategory="不用带脑子听">不用带脑子听</div>
    <div class="music-sub-tab" data-subcategory="听了静不下心">听了静不下心</div>
  </div>
  
  <div class="review-container">

    <div class="review-card" data-category="音乐" data-subcategory="不用带脑子听">
      <h3>DARARI</h3>
      <span class="tag">音乐</span>
      <span class="sub-tag">不用带脑子听</span>
      <div class="rating">⭐⭐⭐⭐ (4/5)</div>
      <p class="desc">重温盒曲中，仿佛回到了不是毒妇的日子，1'30金本芳典的两句乃全曲点睛之笔，只能说太好听了...进度条拉起来...红头发染起来...</p>
      <div class="date">2026.03.26</div>
    </div>

    <div class="review-card" data-category="综艺">
      <h3>开始捉迷藏1</h3>
      <span class="tag">综艺</span> 
      <div class="rating">⭐⭐⭐ (3/5)</div>
      <p class="desc">超级好看！很爱孟欢&楼嘉豪</p>
      <div class="date">2026.03.23</div>
    </div>

    <div class="review-card" data-category="综艺">
      <h3>开始捉迷藏2</h3>
      <span class="tag">综艺</span> 
      <div class="rating">⭐⭐ (2/5)</div>
      <p class="desc">不如第一季。纯代餐节目</p>
      <div class="date">2026.03.23</div>
    </div>

    <div class="review-card" data-category="音乐" data-subcategory="不用带脑子听">
      <h3>一路顺风</h3>
      <span class="tag">音乐</span>
      <span class="sub-tag">不用带脑子听</span>
      <div class="rating">⭐⭐⭐⭐ (4/5)</div>
      <p class="desc">词曲很抒情温柔，闽台语歌曲，卢广仲的声音很加分，我爱卢广仲</p>
      <div class="date">2026.03.23</div>
    </div>

    <div class="review-card" data-category="音乐" data-subcategory="不用带脑子听">
      <h3>轻轻</h3>
      <span class="tag">音乐</span>
      <span class="sub-tag">不用带脑子听</span>
      <div class="rating">⭐⭐⭐⭐⭐ (满分)</div>
      <p class="desc">卢广仲的声音如同巧克力一样划过耳朵，很美味了...</p>
      <div class="date">2026.03.23</div>
    </div>

    <div class="review-card" data-category="书籍">
      <h3>杀死一只知更鸟</h3>
      <span class="tag">书籍</span>
      <div class="rating">⭐⭐⭐⭐⭐ (满分)</div>
      <p class="desc">我学到了我们一起学会原谅吧，没体会到racist...果然每个人看书的想法都不一样阿...</p>
      <div class="date">2026.02.15</div>
    </div>
      
    <div class="review-card" data-category="电影">
      <h3>追爱大作战</h3>
      <span class="tag">电影</span>
      <div class="rating">⭐⭐ (2/5)</div>
      <p class="desc">看过爱情公寓大电影等烂片爱好者可能会喜欢的台区电影，当之无愧的院线爆米花电影，陈柏霖扮丑演了一个啥子，傻子。但是我想看帅气的陈柏霖...为什么会看这部剧呢？因为卢广仲客串了3min哈哈哈，我真是疯了...</p>
      <div class="date">2026.01.20</div>
    </div>
      
    <div class="review-card" data-category="电影">
      <h3>星河入梦</h3>
      <span class="tag">电影</span>
      <div class="rating">⭐⭐⭐ (3/5)</div>
      <p class="desc">我只能说这才是我想走进电影院看的电影，不煽情无爱果，好片！而且呢，特效真的很好看，定格可以躺的影厅，看累了睡觉也舒服，九夜吃啥竟然能睡着。太不可思议了...真的很好看kkk，真的。</p>
      <div class="date">2026.03.05</div>
    </div>
      
    <div class="review-card" data-category="书籍">
      <h3>云边有个小卖部</h3>
      <span class="tag">书籍</span>
      <div class="rating">⭐⭐⭐⭐ (4/5)</div>
      <p class="desc">张嘉佳的文字总是能精准戳中泪点，云边镇的故事有笑有泪，外婆的爱太好哭了。离开的人会变成星星，照亮回家的路。</p>
      <div class="date">2026.01.10</div>
    </div>
      
    <div class="review-card" data-category="电影">
      <h3>周处除三害</h3>
      <span class="tag">电影</span>
      <div class="rating">⭐⭐⭐⭐⭐ (满分)</div>
      <p class="desc">年度最佳华语片之一，节奏紧凑，人物刻画立体。人这一生，总要做一件对的事，哪怕是最后一件。</p>
      <div class="date">2026.02.28</div>
    </div>

    <div class="review-card" data-category="音乐" data-subcategory="听了静不下心">
      <h3>早安晨之美</h3>
      <span class="tag">音乐</span>
      <span class="sub-tag">听了静不下心</span>
      <div class="rating">⭐⭐⭐⭐⭐ (满分)</div>
      <p class="desc">卢广仲的快乐歌，听着就想跟着晃脑袋，适合早上起床当闹钟，一整天都有好心情～</p>
      <div class="date">2026.03.23</div>
    </div>
  </div>
</main>

<footer>
  © 2026 {siteName} | 小庭严肃评价！
</footer>

<script>
  const tabs = document.querySelectorAll('.category-tab');
  const subTabs = document.getElementById('musicSubTabs');
  const musicSubTabs = document.querySelectorAll('.music-sub-tab');
  const cards = document.querySelectorAll('.review-card');
  let currentCategory = '全部';
  let currentSubCategory = '全部';

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentCategory = tab.dataset.category;
      currentSubCategory = '全部';

      if (currentCategory === '音乐') {
        subTabs.style.display = 'flex';
        musicSubTabs.forEach(t => t.classList.remove('active'));
        musicSubTabs[0].classList.add('active');
      } else {
        subTabs.style.display = 'none';
      }
      filterCards();
    });
  });

  musicSubTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      musicSubTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentSubCategory = tab.dataset.subcategory;
      filterCards();
    });
  });

  function filterCards() {
    cards.forEach(card => {
      const cardCategory = card.dataset.category;
      const cardSubCategory = card.dataset.subcategory || '全部';
      let show = false;

      if (currentCategory === '全部') {
        show = true;
      } else if (currentCategory === '音乐') {
        show = cardCategory === '音乐' && (currentSubCategory === '全部' || cardSubCategory === currentSubCategory);
      } else {
        show = cardCategory === currentCategory;
      }
      card.style.display = show ? 'block' : 'none';
    });
  }
</script>
</body>
</html>