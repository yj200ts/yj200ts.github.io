const total = diaryEntries.length;
const happyCount = diaryEntries.filter(x => x.mood === "开心").length;
const calmCount = diaryEntries.filter(x => x.mood === "平静").length;
const angryCount = diaryEntries.filter(x => x.mood === "愤怒").length;
const sadCount = diaryEntries.filter(x => x.mood === "伤心").length;

let noticeText = "小庭最近心情很美丽呀！";
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>小日记</title>
<style is:raw>
/* ========== 真正古早风·2008年QQ空间/论坛风格 ========== */
* { margin:0; padding:0; box-sizing:border-box; }

body {
    font-family: SimSun, "宋体", sans-serif !important; /* 强制宋体 */
    background: #FFF0F6;
    background-image: radial-gradient(pink 1px, transparent 1px);
    background-size: 20px 20px;
    font-size: 14px;
    line-height: 1.6;
    color: #333;
}

/* ========== 导航栏：老式边框 + 粉色 ========== */
nav {
    width: 92%;
    max-width: 800px;
    margin: 10px auto;
    border: 2px solid #F4A7C1;
    background: #FFF;
    padding: 8px;
    text-align: center;
}
.nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
}
.nav a {
    color: #C45A81;
    text-decoration: none;
    font-size: 14px;
    padding: 4px 8px;
    border: 1px solid #F4A7C1;
    background: #FFE6F0;
    font-family: SimSun, "宋体" !important;
}
.nav a:hover {
    background: #F4A7C1;
    color: #FFF;
}
.nav a[href="/diary"] {
    background: #F4A7C1;
    color: #FFF;
    font-weight: normal;
}

/* BGM 图片 + 标题 组合 */
.bgm-group {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 10px;
  cursor: pointer;
}
.bgm-img {
  width: 50px;
  height: auto;
  border: 2px solid #f4a7c1;
  border-radius: 4px;
}
.bgm-title {
  border: 1px solid #f4a7c1;
  background: #fff;
  padding: 4px 8px;
  font-size: 12px;
  color: #e64980;
  font-family: SimSun, "宋体";
}

/* 小音乐按钮 */
.music-btn {
  position: fixed;
  bottom: 12px;
  right: 12px;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #f8a5c2;
  color: #fff;
  border: none;
  font-size: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 6px rgba(0,0,0,0.1);
  z-index: 9999;
}

/* ========== 顶部滚动提示条 ========== */
.tips {
    width: 92%;
    max-width: 800px;
    margin: 0 auto 8px;
    padding: 4px;
    border: 1px dashed #F4A7C1;
    background: #FFF5FA;
    color: #E64980;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
}
.tips span {
    display: inline-block;
    animation: run 12s linear infinite;
}
@keyframes run {
    0% { transform: translateX(100%); }
    100% { transform: translateX(-100%); }
}

/* ========== 心情标签：老式按钮 ========== */
.tabs {
    width: 92%;
    max-width: 800px;
    margin: 0 auto 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    justify-content: center;
}
.tab {
    padding: 4px 8px;
    border: 1px solid #999;
    background: #EEE;
    font-family: SimSun, "宋体" !important;
    font-size: 13px;
    cursor: pointer;
}
.tab.happy { background: #FFDDF1; color: #E64980; border-color: #E64980; }
.tab.calm { background: #E8F4FD; color: #4285F4; border-color: #4285F4; }
.tab.angry { background: #FFE5E5; color: #EA4335; border-color: #EA4335; }
.tab.sad { background: #F3E5FF; color: #9C27B0; border-color: #9C27B0; }

/* ========== 日记卡片：老式边框 + 纯白底板 ========== */
.box {
    width: 92%;
    max-width: 800px;
    margin: 0 auto;
}
.card {
    border: 1px solid #C45A81;
    background: #FFF;
    padding: 10px;
    margin-bottom: 8px;
}
.tag {
    font-size: 12px;
    padding: 2px 6px;
    border: 1px solid #CCC;
    display: inline-block;
    margin-bottom: 6px;
    font-family: SimSun, "宋体" !important;
}
.tag.happy { background: #FFDDF1; color: #E64980; border-color: #E64980; }
.tag.calm { background: #E8F4FD; color: #4285F4; border-color: #4285F4; }
.tag.angry { background: #FFE5E5; color: #EA4335; border-color: #EA4335; }
.tag.sad { background: #F3E5FF; color: #9C27B0; border-color: #9C27B0; }

.date {
    color: #777;
    font-size: 12px;
    margin-bottom: 6px;
}
.card p {
    font-size: 14px;
    line-height: 1.6;
    color: #333;
}

/* ========== 私密日记：老式密码框 ========== */
.priv {
    border: 1px dashed #E64980;
    padding: 8px;
    margin-top: 8px;
    background: #FFF5FA;
}
.priv input {
    width: 100%;
    padding: 4px;
    margin: 4px 0;
    border: 1px solid #E64980;
    font-family: SimSun, "宋体" !important;
    font-size: 13px;
}
.priv button {
    width: 100%;
    padding: 4px;
    background: #E64980;
    color: #FFF;
    border: none;
    font-family: SimSun, "宋体" !important;
    cursor: pointer;
}
.unlocked-content {
    border: 1px solid #F4A7C1;
    background: #FFF5FA;
    padding: 8px;
    margin-top: 6px;
    line-height: 1.6;
}

/* ========== 图片 ========== */
.card img {
    max-width: 50%;
    margin-top: 8px;
    border: 1px solid #CCC;
}

footer {
  text-align: center;
  margin: 30px 0;
  color: #999;
  font-size: 12px;
}

/* ========== 手机端不缩小 ========== */
@media (max-width:600px) {
    body { font-size:15px !important; }
    .nav a { font-size:14px !important; }
    .card p { font-size:15px !important; }
}
</style>
</head>

<body>

<nav>
    <div class="nav">
        <a href="/">首页</a>
        <a href="/diary">小日记</a>
        <a href="/review">音影书评</a>
        <a href="/guestbook">留言板</a>
        <a href="/ask">提问箱</a>
        <a href="/postcard">明信片</a>
        <a href="/about">关于我</a>
    </div>
</nav>

<!-- 点击播放BGM：图片 + 标题小框 -->
<div class="bgm-group" id="bgmGroup">
  <img src="/assets/beijing.PNG" class="bgm-img" alt="BGM">
  <div class="bgm-title">BGM: 陈粒—奇妙能力歌</div>
</div>

<div class="tips"><span>{noticeText}</span></div>

<div class="tabs">
    <button class="tab" onclick="show('all')">全部({total})</button>
    <button class="tab happy" onclick="show('开心')">开心({happyCount})</button>
    <button class="tab calm" onclick="show('平静')">平静({calmCount})</button>
    <button class="tab angry" onclick="show('愤怒')">愤怒({angryCount})</button>
    <button class="tab sad" onclick="show('伤心')">伤心({sadCount})</button>
</div>

<div class="box">
{diaryEntries.map((it, i) => {
    const boxId = `box_${i}`;
    const pwId = `pw_${i}`;
    const safeContent = it.content.replace(/'/g, "\\'").replace(/"/g, '\\"').replace(/\n/g, '\\n');

    return (
        <div class="card" data-mood={it.mood}>
            {it.mood === "开心" && <span class="tag happy">开心</span>}
            {it.mood === "平静" && <span class="tag calm">平静</span>}
            {it.mood === "愤怒" && <span class="tag angry">愤怒</span>}
            {it.mood === "伤心" && <span class="tag sad">伤心</span>}
            <div class="date">{it.date}</div>

            {!it.private ? (
                <p>{it.content}</p>
            ) : (
                <div class="priv" id={boxId}>
                    🔒私密日记
                    <input type="password" id={pwId} placeholder="密码" />
                    <button onclick={`unlock('${boxId}','${pwId}','${safeContent}')`}>解锁</button>
                </div>
            )}

            {it.image && <img src={it.image} />}
        </div>
    );
})}
</div>

<!-- 音乐小按钮 -->
<button class="music-btn" id="musicBtn">🎵</button>

<script is:inline>
// 背景音乐
const audio = new Audio('/bgm.mp3');
audio.loop = true;
audio.volume = 0.3;
let isPlaying = false;
const btn = document.getElementById('musicBtn');

function toggleBGM() {
  if (isPlaying) {
    audio.pause();
    btn.textContent = "🎵";
  } else {
    audio.play();
    btn.textContent = "🔇";
  }
  isPlaying = !isPlaying;
}

// 点击整个区域都能播放
document.getElementById('bgmGroup').onclick = toggleBGM;
btn.onclick = toggleBGM;

// 日记筛选
function show(m){
    document.querySelectorAll(".card").forEach(c=>{
        c.style.display = m=="all"||c.dataset.mood==m ? "block" : "none";
    });
}

// 解锁私密日记
function unlock(boxId,pwId,content){
    const pw = document.getElementById(pwId).value;
    if(pw === "19981025"){
        document.getElementById(boxId).innerHTML = `
        <div class="unlocked-content">✅解锁成功<br><br>📖日记内容：<br>${content}</div>`;
    }else{
        alert("密码错啦！");
    }
}
</script>

<footer>
  © 2026 小庭小世界 | 这是小庭的日记，小庭今天的心情怎么样呢？
</footer>

</body>
</html>