---
const siteName = "小庭小世界";
const slogan = "这是我的地盘！hhh";
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteName}</title>
  <style is:raw>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: SimSun, "宋体", sans-serif;
      background: #fff0f6;
      background-image: radial-gradient(pink 1px, transparent 1px);
      background-size: 20px 20px;
      font-size: 14px;
      line-height: 1.6;
      color: #333;
    }

    nav {
      width: 92%;
      max-width: 800px;
      margin: 10px auto;
      border: 2px solid #F4A7C1;
      background: #FFF;
      padding: 8px;
      text-align: center;
    }
    .nav-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }
    .nav-links a {
      color: #C45A81;
      text-decoration: none;
      font-size: 14px;
      padding: 4px 8px;
      border: 1px solid #F4A7C1;
      background: #FFE6F0;
      font-family: SimSun, "宋体" !important;
    }
    .nav-links a:hover {
      background: #F4A7C1;
      color: #FFF;
    }
    .nav-links a.active {
      background: #F4A7C1;
      color: #FFF;
      font-weight: normal;
    }

    .banner {
      max-width: 800px;
      margin: 20px auto;
      padding: 22px 10px;
      text-align: center;
      background: repeating-linear-gradient(
        -45deg,
        #ffffff,
        #ffffff 10px,
        #ffe6f0 10px,
        #ffe6f0 20px
      );
      border: 1px solid #C45A81;
    }
    .banner h1 {
      font-size: 20px;
      color: #e64980;
      margin-bottom: 4px;
      font-family: SimSun, "宋体";
    }
    .banner p {
      font-size: 14px;
      color: #666;
    }

    .sections {
      max-width: 800px;
      margin: 20px auto;
      padding: 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .section-card {
      background: #fff;
      border: 1px solid #C45A81;
      padding: 10px;
    }
    .section-card h3 {
      font-size: 14px;
      color: #e64980;
      margin-bottom: 6px;
      font-family: SimSun, "宋体";
    }
    .section-card p {
      font-size: 14px;
      margin-bottom: 6px;
    }
    .section-card a {
      font-size: 14px;
      color: #C45A81;
      text-decoration: none;
    }

    .latest {
      max-width: 800px;
      margin: 20px auto;
      padding: 0 1rem;
    }
    .latest h2 {
      font-size: 16px;
      color: #e64980;
      margin-bottom: 10px;
      font-family: SimSun, "宋体";
    }
    .latest-item {
      background: #fff;
      border: 1px solid #C45A81;
      padding: 6px 10px;
      margin-bottom: 8px;
      font-size: 14px;
    }

    footer {
      text-align: center;
      margin: 30px 0;
      color: #999;
      font-size: 12px;
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-links">
    <a href="/" class="active">首页</a>
    <a href="/diary">小日记</a>
    <a href="/review">音影书评</a>
    <a href="/guestbook">留言板</a>
    <a href="/ask">提问箱</a>
    <a href="/postcard">明信片</a>
    <a href="/about">关于我</a>
  </div>
</nav>

<section class="banner">
  <h1>欢迎来到 {siteName}</h1>
  <p>{slogan}</p>
</section>

<section class="sections">
  <div class="section-card">
    <h3>📝 小日记</h3>
    <p>日常碎碎碎碎碎碎念！</p>
    <a href="/diary">去看看 →</a>
  </div>
  <div class="section-card">
    <h3>🎵 音影书评</h3>
    <p>严肃评价！</p>
    <a href="/review">去看看 →</a>
  </div>
  <div class="section-card">
    <h3>📮🎑 postcard</h3>
    <p>和我一起互寄吧！</p>
    <a href="/postcard">去看看 →</a>
  </div>
  <div class="section-card">
    <h3>💬 留言板</h3>
    <p>留下你的足迹与心意流</p>
    <a href="/guestbook">去看看 →</a>
  </div>
</section>

<section class="latest">
  <h2>最新动态</h2>
  <div class="latest-item">⚙️ 2026-03-23 | 更新了影音书评、留言板</div>
  <div class="latest-item">⚙️ 2026-03-22 | 更新了小日记和关于我</div>
</section>

<footer>
  © 2026 {siteName} | 这是小庭的地盘，正在吃茄子的人不得入内
</footer>

</body>
</html>
