---
const siteName = "小庭小世界";
const slogan = "这是我的地盘！hhh";
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteName}</title>
  <style is:raw>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: SimSun, "宋体", sans-serif;
      background: #fff0f6;
      background-image: radial-gradient(pink 1px, transparent 1px);
      background-size: 20px 20px;
      font-size: 14px;
      line-height: 1.6;
      color: #333;
    }

    nav {
      width: 92%;
      max-width: 800px;
      margin: 10px auto;
      border: 2px solid #F4A7C1;
      background: #FFF;
      padding: 8px;
      text-align: center;
    }
    .nav-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }
    .nav-links a {
      color: #C45A81;
      text-decoration: none;
      font-size: 14px;
      padding: 4px 8px;
      border: 1px solid #F4A7C1;
      background: #FFE6F0;
      font-family: SimSun, "宋体" !important;
    }
    .nav-links a:hover {
      background: #F4A7C1;
      color: #FFF;
    }
    .nav-links a.active {
      background: #F4A7C1;
      color: #FFF;
      font-weight: normal;
    }

    .banner {
      max-width: 800px;
      margin: 20px auto;
      padding: 22px 10px;
      text-align: center;
      background: repeating-linear-gradient(
        -45deg,
        #ffffff,
        #ffffff 10px,
        #ffe6f0 10px,
        #ffe6f0 20px
      );
      border: 1px solid #C45A81;
    }
    .banner h1 {
      font-size: 20px;
      color: #e64980;
      margin-bottom: 4px;
      font-family: SimSun, "宋体";
    }
    .banner p {
      font-size: 14px;
      color: #666;
    }

    /* 游戏盒子 */
    .game-box {
      width: fit-content;
      margin: 0 auto 25px;
      padding: 15px;
      background: #fff;
      border: 3px solid #f4a7c1;
      border-style: wavy;
      position: relative;
    }
    .game-box::before {
      content: "";
      position: absolute;
      inset: 6px;
      border: 2px solid #f8c8dc;
      border-style: wavy;
      pointer-events: none;
    }

    /* 所有格子都有方块！！ */
    .puzzle {
      display: grid;
      grid-template-columns: repeat(3, 60px);
      gap: 6px;
    }
    .puzzle-item {
      width: 60px;
      height: 60px;
      background: #ffe6f0;
      border: 2px solid #f4a7c1;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      font-weight: bold;
      color: #e64980;
      cursor: pointer;
    }
    /* 只有空白格子隐藏文字，保留方块 */
    .puzzle-item.empty {
      color: transparent;
    }

    .game-info {
      text-align: center;
      color: #e64980;
      margin-bottom: 10px;
      font-size: 14px;
    }
    .reset-btn {
      margin: 10px auto 0;
      padding: 4px 10px;
      border: 1px solid #f4a7c1;
      background: #fff;
      color: #e64980;
      border-radius: 6px;
      cursor: pointer;
      display: block;
      font-size: 13px;
    }

    .sections {
      max-width: 800px;
      margin: 20px auto;
      padding: 0 1rem;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .section-card {
      background: #fff;
      border: 1px solid #C45A81;
      padding: 10px;
    }
    .section-card h3 {
      font-size: 14px;
      color: #e64980;
      margin-bottom: 6px;
      font-family: SimSun, "宋体";
    }
    .section-card p {
      font-size: 14px;
      margin-bottom: 6px;
    }
    .section-card a {
      font-size: 14px;
      color: #C45A81;
      text-decoration: none;
    }

    .latest {
      max-width: 800px;
      margin: 20px auto;
      padding: 0 1rem;
    }
    .latest h2 {
      font-size: 16px;
      color: #e64980;
      margin-bottom: 10px;
      font-family: SimSun, "宋体";
    }
    .latest-item {
      background: #fff;
      border: 1px solid #C45A81;
      padding: 6px 10px;
      margin-bottom: 8px;
      font-size: 14px;
    }

    footer {
      text-align: center;
      margin: 30px 0;
      color: #999;
      font-size: 12px;
    }
  </style>
</head>
<body>

<nav>
  <div class="nav-links">
    <a href="/" class="active">首页</a>
    <a href="/diary">小日记</a>
    <a href="/review">音影书评</a>
    <a href="/guestbook">留言板</a>
    <a href="/ask">提问箱</a>
    <a href="/postcard">明信片</a>
    <a href="/about">关于我</a>
  </div>
</nav>

<section class="banner">
  <h1>欢迎来到 {siteName}</h1>
  <p>{slogan}</p>
</section>

<div class="game-box">
  <div class="game-info">步数：<span id="step">0</span></div>
  <div class="puzzle" id="puzzle"></div>
  <button class="reset-btn" onclick="initPuzzle()">重新开始</button>
</div>

<section class="sections">
  <div class="section-card">
    <h3>📝 小日记</h3>
    <p>日常碎碎碎碎碎碎念！</p>
    <a href="/diary">去看看 →</a>
  </div>
  <div class="section-card">
    <h3>🎵 音影书评</h3>
    <p>严肃评价！</p>
    <a href="/review">去看看 →</a>
  </div>
  <div class="section-card">
    <h3>📮🎑 postcard</h3>
    <p>和我一起互寄吧！</p>
    <a href="/postcard">去看看 →</a>
  </div>
</section>

<section class="latest">
  <h2>最新动态</h2>
  <div class="latest-item">⚙️ 2026-03-25 | 更新了明信片</div>
  <div class="latest-item">⚙️ 2026-03-23 | 更新了音影书评、留言板</div>
  <div class="latest-item">⚙️ 2026-03-22 | 更新了小日记和关于我</div>
</section>

<footer>
  © 2026 {siteName} | 这是小庭的地盘，正在吃茄子的人不得入内
</footer>

<script>
let step = 0;
let arr = [1,2,3,4,5,6,7,8,0];

function initPuzzle() {
  step = 0;
  document.getElementById("step").innerText = step;
  arr = [1,2,3,4,5,6,7,8,0];
  for(let i=arr.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [arr[i],arr[j]]=[arr[j],arr[i]];
  }
  render();
}

function render() {
  const p = document.getElementById("puzzle");
  p.innerHTML = "";
  arr.forEach(n => {
    const d = document.createElement("div");
    d.className = "puzzle-item " + (n === 0 ? "empty" : "");
    d.innerText = n || "";
    if(n !== 0) d.onclick = () => move(n);
    p.appendChild(d);
  });
}

function move(num) {
  const i = arr.indexOf(num);
  const e = arr.indexOf(0);
  const ok = [i-1, i+1, i-3, i+3].includes(e);
  if(!ok) return;
  step++;
  document.getElementById("step").innerText = step;
  [arr[i],arr[e]] = [arr[e],arr[i]];
  render();
  if(arr.join() === [1,2,3,4,5,6,7,8,0].join()){
    setTimeout(()=>alert("🎉 通关啦！你太棒啦！"),300);
  }
}

window.onload = initPuzzle;
</script>

</body>
</html>