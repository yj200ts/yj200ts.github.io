---
const siteName = "小庭小世界";
const slogan = "这是我的地盘！hhh";
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteName}</title>
  <style is:raw>
    /* 全局样式 */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: "Microsoft Yahei", sans-serif;
      /* 极简写法：纯色背景 + 高对比度波点，必显！ */
      background-color: #fff0f6; /* 基础粉色底 */
      background-image: radial-gradient(#e64980 2px, transparent 2px); /* 深粉色波点 */
      background-size: 30px 30px; /* 波点间距，越大越稀疏 */
      background-position: 0 0; /* 波点起始位置 */
      color: #5a5a5a;
      line-height: 1.6;
      min-height: 100vh; /* 铺满整个页面 */
    }

    /* 导航栏 */
    nav {
      background: rgba(255, 255, 255, 0.9);
      padding: 1rem 2rem;
      box-shadow: 0 2px 10px rgba(230, 73, 128, 0.1);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-logo {
      font-size: 1.5rem;
      font-weight: bold;
      color: #e64980;
      text-decoration: none;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
    }
    .nav-links a {
      text-decoration: none;
      color: #666;
    }
    .nav-links a:hover {
      color: #e64980;
    }

    /* 粉色渐变 Banner */
    .banner {
      background: linear-gradient(135deg, #f8a5c2 0%, #fadadd 100%);
      color: white;
      padding: 4rem 2rem;
      text-align: center;
      /* 遮挡banner内的波点 */
      background-image: linear-gradient(135deg, #f8a5c2 0%, #fadadd 100%);
    }
    .banner h1 {
      font-size: 2.2rem;
      margin-bottom: 0.8rem;
    }
    .banner p {
      font-size: 1.1rem;
      opacity: 0.9;
    }

    /* 卡片布局 */
    .sections {
      max-width: 1200px;
      margin: 3rem auto;
      padding: 0 2rem;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }
    .section-card {
      background: rgba(255, 255, 255, 0.85);
      padding: 2rem;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(230, 73, 128, 0.1);
    }
    .section-card h3 {
      color: #e64980;
      margin-bottom: 1rem;
      font-size: 1.2rem;
    }
    .section-card p {
      color: #777;
      margin-bottom: 1.5rem;
      font-size: 0.95rem;
    }
    .section-card a {
      color: #e64980;
      text-decoration: none;
      font-weight: bold;
      font-size: 0.95rem;
    }

    /* 最新动态 */
    .latest {
      max-width: 1200px;
      margin: 0 auto 3rem;
      padding: 0 2rem;
    }
    .latest h2 {
      color: #e64980;
      margin-bottom: 1.5rem;
      font-size: 1.4rem;
    }
    .latest-item {
      background: rgba(255, 255, 255, 0.85);
      padding: 1rem;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(230, 73, 128, 0.1);
    }

    /* 底部 */
    footer {
      background: rgba(255, 255, 255, 0.9);
      padding: 2rem;
      text-align: center;
      color: #999;
      border-top: 1px solid rgba(230, 73, 128, 0.15);
      /* 遮挡footer内的波点 */
      background-image: none;
    }
  </style>
</head>
<body>
  <!-- 导航 -->
  <nav>
    <div class="nav-container">
      <a href="/" class="nav-logo">{siteName}</a>
      <div class="nav-links">
        <a href="/">首页</a>
        <a href="/diary">小日记</a>
        <a href="/review">音影书评</a>
        <a href="/guestbook">留言板</a>
        <a href="/ask">提问箱</a>
        <a href="/postcard">明信片</a>
        <a href="/about">关于我</a>
      </div>
    </div>
  </nav>

  <!-- 粉色渐变 Banner -->
  <section class="banner">
    <h1>欢迎来到 {siteName}</h1>
    <p>{slogan}</p>
  </section>

  <!-- 卡片模块 -->
  <section class="sections">
    <div class="section-card">
      <h3>📝 小日记</h3>
      <p>日常碎碎碎碎碎碎念！</p>
      <a href="/diary">去看看 →</a>
    </div>
    <div class="section-card">
      <h3>🎵音影书评</h3>
      <p>严肃评价！</p>
      <a href="/review">去看看 →</a>
    </div>
    <div class="section-card">
      <h3>📮🎑 postcard</h3>
      <p>和我一起互寄吧！</p>
      <a href="/postcard">去看看 →</a>
    </div>
    <div class="section-card">
      <h3>💬 留言板</h3>
      <p>留下你的足迹与心意流</p>
      <a href="/guestbook">去看看 →</a>
    </div>
  </section>

  <!-- 更新明细 -->
  <section class="latest">
    <h2>最新动态</h2>
<div class="latest-item" style="margin-bottom: 1rem;">
  <span>⚙️ 2026-03-23 | 更新了影音书评、留言板 </span>
</div>

<div class="latest-item" style="margin-bottom: 1rem;">
  <span>⚙️ 2026-03-22 | 更新了小日记和关于我 </span>
</div>
  </section>

  <!-- 底部 -->
  <footer>
    <p>© 2026 {siteName} | 这是小庭的地盘，正在吃茄子的人不得入内</p>
  </footer>
</body>
</html>